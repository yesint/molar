[env]
#----------------------------------------------
# Variables for linking with Gromacs
#----------------------------------------------

# Location of Gromacs source tree
GROMACS_SOURCE_DIR = "/home/user/install/gromacs"

# Location of Gromacs *build* directory (for generated headers)
GROMACS_BUILD_DIR = "/home/user/install/gromacs/build"

# Location of installed gromacs libraries
GROMACS_LIB_DIR = "/home/user/programs/gromacs/lib64"
